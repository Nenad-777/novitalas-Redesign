{
  "headers": [
    {
      "source": "/og/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/share/(.*)", "destination": "/share/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}

{
  "headers": [
    {
      "source": "/og/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/talibani-otvorili-vatru-na-protest-za-prava-zena",
      "destination": "/geopolitika/talibani-otvorili-vatru-na-protest-za-prava-zena",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/share/(.*)", "destination": "/share/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
